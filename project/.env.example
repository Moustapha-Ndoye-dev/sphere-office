# Public frontend variables. The anon key is designed to be exposed to browsers.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key
VITE_COMPANY_NINEA=
VITE_COMPANY_RCCM=

# Serverless-only variables. Never prefix the service-role key with VITE_.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key

# Optional comma-separated cross-origin allowlist. Same-origin requests work without it.
API_ALLOWED_ORIGINS=https://www.example.com
